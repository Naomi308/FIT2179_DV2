{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.2.json",
  "title": {
    "text": "Daily Pedestrian Activity and Major Event Markers (2024–2026)",
    "anchor": "start",
    "font": "Arial",
    "fontSize": 20,
    "fontWeight": "bold",
    "subtitleFont": "Arial",
    "subtitleFontSize": 12,
    "subtitleColor": "#5f6b7a",
    "offset": 16
  },
  "data": {
    "url": "https://raw.githubusercontent.com/Naomi308/FIT2129_DV2/master/melbourne/data/pedestrian_daily_2020_2026_cleaned.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {"calculate": "toDate(datum.date)", "as": "date_clean"},
    {"calculate": "toNumber(datum.total_count)", "as": "pedestrian_count"},
    {"calculate": "toNumber(datum.sensor_count)", "as": "sensor_count_clean"},
    {
      "filter": "datum.date_clean >= toDate('2024-05-15') && datum.date_clean <= toDate('2026-05-14')"
    }
  ],
  "vconcat": [
    {
      "width": 900,
      "height": 330,
      "layer": [
        {
          "mark": {
            "type": "area",
            "interpolate": "monotone",
            "color": "#1170aa",
            "opacity": 0.82
          },
          "encoding": {
            "x": {
              "field": "date_clean",
              "type": "temporal",
              "scale": {"domain": {"param": "brush"}},
              "axis": {
                "title": null,
                "format": "%b %Y",
                "labelFont": "Arial",
                "labelFontSize": 11,
                "labelColor": "#1f2937",
                "grid": true
              }
            },
            "y": {
              "field": "pedestrian_count",
              "type": "quantitative",
              "axis": {
                "title": "Daily pedestrian count",
                "labelFont": "Arial",
                "labelFontSize": 11,
                "titleFont": "Arial",
                "titleFontSize": 12,
                "grid": true,
                "format": ",.0f"
              }
            },
            "tooltip": [
              {
                "field": "date_clean",
                "type": "temporal",
                "title": "Date",
                "format": "%d %b %Y"
              },
              {
                "field": "pedestrian_count",
                "type": "quantitative",
                "title": "Daily pedestrian count",
                "format": ",.0f"
              },
              {
                "field": "sensor_count_clean",
                "type": "quantitative",
                "title": "Sensors active",
                "format": ",.0f"
              }
            ]
          }
        },
        {
          "mark": {
            "type": "line",
            "interpolate": "monotone",
            "color": "#1f4e79",
            "strokeWidth": 1.4,
            "opacity": 0.95
          },
          "encoding": {
            "x": {
              "field": "date_clean",
              "type": "temporal",
              "scale": {"domain": {"param": "brush"}}
            },
            "y": {"field": "pedestrian_count", "type": "quantitative"}
          }
        },
        {
          "data": {
            "values": [
              {
                "event_date": "2024-09-28",
                "event_name": "AFL Grand Final 2024",
                "event_type": "Sport",
                "venue": "MCG"
              },
              {
                "event_date": "2024-11-05",
                "event_name": "Melbourne Cup 2024",
                "event_type": "Sport",
                "venue": "Flemington"
              },
              {
                "event_date": "2025-01-12",
                "event_name": "Australian Open 2025",
                "event_type": "Sport",
                "venue": "Melbourne Park"
              },
              {
                "event_date": "2025-03-06",
                "event_name": "Moomba 2025",
                "event_type": "Culture",
                "venue": "Melbourne CBD / Yarra"
              },
              {
                "event_date": "2025-03-13",
                "event_name": "F1 Australian GP 2025",
                "event_type": "Sport",
                "venue": "Albert Park"
              },
              {
                "event_date": "2025-09-27",
                "event_name": "AFL Grand Final 2025",
                "event_type": "Sport",
                "venue": "MCG"
              },
              {
                "event_date": "2025-11-04",
                "event_name": "Melbourne Cup 2025",
                "event_type": "Sport",
                "venue": "Flemington"
              },
              {
                "event_date": "2026-01-12",
                "event_name": "Australian Open 2026",
                "event_type": "Sport",
                "venue": "Melbourne Park"
              },
              {
                "event_date": "2026-03-05",
                "event_name": "Moomba 2026",
                "event_type": "Culture",
                "venue": "Melbourne CBD / Yarra"
              },
              {
                "event_date": "2026-03-05",
                "event_name": "F1 Australian GP 2026",
                "event_type": "Sport",
                "venue": "Albert Park"
              }
            ]
          },
          "transform": [
            {"calculate": "toDate(datum.event_date)", "as": "event_date_clean"}
          ],
          "mark": {
            "type": "rule",
            "strokeDash": [4, 4],
            "strokeWidth": 1.5,
            "opacity": 0.9
          },
          "encoding": {
            "x": {
              "field": "event_date_clean",
              "type": "temporal",
              "scale": {"domain": {"param": "brush"}}
            },
            "color": {
              "field": "event_type",
              "type": "nominal",
              "scale": {
                "domain": ["Sport", "Culture"],
                "range": ["#ef4444", "#f59e0b"]
              },
              "legend": {
                "title": "Event type",
                "orient": "top-right",
                "labelFont": "Arial",
                "labelFontSize": 11,
                "titleFont": "Arial",
                "titleFontSize": 12,
                "titleFontWeight": "bold"
              }
            },
            "tooltip": [
              {"field": "event_name", "type": "nominal", "title": "Event"},
              {"field": "event_type", "type": "nominal", "title": "Type"},
              {"field": "venue", "type": "nominal", "title": "Venue"},
              {
                "field": "event_date_clean",
                "type": "temporal",
                "title": "Date",
                "format": "%d %b %Y"
              }
            ]
          }
        },
        {
          "data": {
            "values": [
              {"event_date": "2024-09-28", "label": "AFL GF"},
              {"event_date": "2024-11-05", "label": "Cup"},
              {"event_date": "2025-01-12", "label": "AO"},
              {"event_date": "2025-03-06", "label": "Moomba"},
              {"event_date": "2025-03-13", "label": "F1"},
              {"event_date": "2025-09-27", "label": "AFL GF"},
              {"event_date": "2025-11-04", "label": "Cup"},
              {"event_date": "2026-01-12", "label": "AO"},
              {"event_date": "2026-03-05", "label": "Moomba / F1"}
            ]
          },
          "transform": [
            {"calculate": "toDate(datum.event_date)", "as": "event_date_clean"}
          ],
          "mark": {
            "type": "text",
            "angle": -45,
            "align": "right",
            "baseline": "middle",
            "dx": -6,
            "dy": -6,
            "font": "Arial",
            "fontSize": 10,
            "fontWeight": "bold",
            "color": "#374151"
          },
          "encoding": {
            "x": {
              "field": "event_date_clean",
              "type": "temporal",
              "scale": {"domain": {"param": "brush"}}
            },
            "y": {"value": 12},
            "text": {"field": "label", "type": "nominal"}
          }
        }
      ]
    },
    {
      "width": 900,
      "height": 90,
      "params": [
        {"name": "brush", "select": {"type": "interval", "encodings": ["x"]}}
      ],
      "mark": {
        "type": "area",
        "interpolate": "monotone",
        "color": "#4c78a8",
        "opacity": 0.75
      },
      "encoding": {
        "x": {
          "field": "date_clean",
          "type": "temporal",
          "scale": {"domain": ["2024-05-15", "2026-05-14"]},
          "axis": {
            "title": "Drag to select a time period",
            "format": "%b %Y",
            "labelFont": "Arial",
            "labelFontSize": 11,
            "titleFont": "Arial",
            "titleFontSize": 12,
            "labelColor": "#1f2937"
          }
        },
        "y": {
          "field": "pedestrian_count",
          "type": "quantitative",
          "axis": {
            "title": null,
            "labelFont": "Arial",
            "labelFontSize": 10,
            "grid": true,
            "format": ",.0f"
          }
        },
        "tooltip": [
          {
            "field": "date_clean",
            "type": "temporal",
            "title": "Date",
            "format": "%d %b %Y"
          },
          {
            "field": "pedestrian_count",
            "type": "quantitative",
            "title": "Daily pedestrian count",
            "format": ",.0f"
          }
        ]
      }
    }
  ],
  "config": {
    "background": "white",
    "view": {"stroke": null},
    "axis": {"domain": false, "ticks": false}
  }
}